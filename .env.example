# Frontend environment variables (copy to .env.local for local overrides)

# API base URL — leave empty when frontend is served from the same origin as the backend
# (same-domain prod or dev proxy). Set to full URL only when on a separate domain.
# Example: VITE_API_BASE_URL=https://api.filesterr.com
VITE_API_BASE_URL=

# Dev proxy target — the Django backend URL used by the Vite dev proxy (server-side only, not bundled).
# Default: http://localhost:8000
# API_TARGET=http://localhost:8000

# Cloudflare Turnstile CAPTCHA site key (public, frontend'de kullanılır)
# Almak için: https://dash.cloudflare.com → Turnstile → Add site
# Test key (geliştirme için — prod'da değiştir):
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
